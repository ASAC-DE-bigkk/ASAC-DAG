# ─────────────────────────────────────────────────────────────────────────────
# .env.commerce — commerce 카테고리 전용 런타임 환경변수 (템플릿)
#
# 이 파일은 dags/domains/commerce/ 번들 안에서 자립한다. DAG 가 임포트될 때
# include/common/env.py 의 load_commerce_env() 가 이 폴더의 .env.commerce 를 읽어
# os.environ 에 **채운다(setdefault)**. 즉 이미 프로세스 환경(루트 .env / compose
# environment:)에 있는 값이 우선이고, 없는 commerce 전용 값만 이 파일이 채운다.
#
# 사용법:
#   cp .env.commerce.example .env.commerce   (또는 Copy-Item)
#   빈 값을 채운다. 서울 API 인증키는 루트 .env 의 SEOUL_API_KEY_COMM(#70). .env.commerce 는 gitignore 됨(시크릿).
#
# 우선순위(높음 → 낮음): 프로세스 env(루트 .env/compose) > .env.commerce > settings.py 기본값
# 경로 override: COMMERCE_ENV_FILE 로 다른 파일을 지정할 수 있다.
# 참조 코드: include/common/settings.py · include/common/env.py · include/common/registry.py
# ─────────────────────────────────────────────────────────────────────────────

# ── 서울 열린데이터광장 OpenAPI (필수) ──────────────────────────────────────
# 인증키는 루트 .env 의 SEOUL_API_KEY_COMM 으로 이관됨(#70).
# SEOUL_PAGE_SIZE: 1회 조회 건수(서울 상한 1000으로 캡).
SEOUL_PAGE_SIZE=1000
# SEOUL_MAX_PAGES: 페이지 수 제한. **비우면(미설정) 무제한 — 끝까지 순회**.
# 일반 API 는 호출 횟수 제한이 없으므로 기본 무제한. 양수만 부분 수집(개발용) 캡.
SEOUL_MAX_PAGES=
SEOUL_REQUEST_DELAY_SECONDS=0.2

# ── 스토리지 백엔드 ─────────────────────────────────────────────────────────
# local = 컨테이너 로컬 볼륨(클라우드 자격증명 불필요) | r2 = Cloudflare R2(boto3 사용·이미지 기본 포함)
STORAGE_BACKEND=local
LOCAL_DATA_ROOT=/opt/airflow/data
# bucket 아래 공통 접두(예: dev/<github_id>). 비우면 {bucket}/raw/commerce/...
COMMERCE_STORAGE_PREFIX=
# 레이어 접두(스테이지/도메인) — bronze→raw 리네임 반영(.env 로 관리).
# 기본값 그대로면 raw/commerce · silver/commerce. 데이터가 raw/commerce 로 이관됨.
COMMERCE_RAW_LAYER=raw/commerce
COMMERCE_SILVER_LAYER=silver/commerce
# raw 마커(리니지) JSON 의 schema_version
SCHEMA_VERSION=v1

# ── Cloudflare R2 (STORAGE_BACKEND=r2 일 때만 필요) ──────────────────────────
# 루트 .env 와 겹치는 값은 ${...} 로 불러온다(로더가 프로세스 env = 루트 .env 로 치환).
# 중복 저장하지 않으며, 이름이 다른 것만 매핑한다(R2_BUCKET ← 루트 R2_DEV_BUCKET_NAME).
# ※ settings.py 는 R2_BUCKET 을 읽는다(루트 .env 의 R2_BUCKET_NAME 과 이름이 다름).
# 루트 .env 에 해당 키가 없다면 ${VAR:-기본값} 또는 실제 값으로 바꿔 넣는다.
R2_ENDPOINT=${R2_DEV_ENDPOINT}
R2_BUCKET=${R2_DEV_BUCKET_NAME:-seoul-dev}
R2_ACCESS_KEY_ID=${R2_DEV_ACCESS_KEY_ID}
R2_SECRET_ACCESS_KEY=${R2_DEV_SECRET_ACCESS_KEY}
R2_REGION=auto

# ── 선택 ────────────────────────────────────────────────────────────────────
# 데이터셋 레지스트리 경로 override(기본: 이 번들의 config/dataset_registry.yaml)
# COMMERCE_REGISTRY_PATH=
